<% content_for :title, "Avisos - Notificação Global" %>

<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6">
        <h1 class="m-0">
          <i class="fas fa-bullhorn mr-2"></i>Notificação Global
        </h1>
      </div>
      <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
          <li class="breadcrumb-item"><a href="#"><%= t('views.common.settings') %></a></li>
          <li class="breadcrumb-item active">Avisos</li>
        </ol>
      </div>
    </div>
  </div>
</div>

<section class="content">
  <div class="container-fluid">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Enviar novo aviso para todos os usuários</h3>
      </div>
      <div class="card-body">
        <%= form_with url: admin_announcements_path, method: :post, class: "needs-validation", local: true do |form| %>
          <div class="row">
            <div class="col-md-12">
              <div class="form-group">
                <%= form.label :message, class: "form-label" do %>
                  Mensagem do Aviso <span class="text-danger">*</span>
                <% end %>
                <%= form.text_area :message, class: "form-control", rows: 5, placeholder: "Ex: O sistema entrará em manutenção amanhã...", required: true %>
                <small class="form-text text-muted mt-2">
                  <i class="fas fa-info-circle"></i> Ao enviar, a notificação será gerada para TODOS os usuários via background job.
                </small>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="form-group">
                <%= form.submit "Enviar Notificação", class: "btn btn-primary" %>
                <%= link_to t('views.common.cancel'), root_path, class: "btn btn-secondary ml-2" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>
