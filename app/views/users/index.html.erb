<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6">
        <h1 class="m-0">
          <i class="fas fa-users mr-2"></i><%= t('views.users.index.header') %>
        </h1>
      </div>
      <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
          <li class="breadcrumb-item active"><%= t('views.users.index.header') %></li>
        </ol>
      </div>
    </div>
  </div>
</div>

<section class="content">
  <div class="container-fluid">
    <!-- Formulário de busca -->
    <div class="card mb-3">
      <div class="card-body">
        <%= search_form_for @q do |f| %>
          <div class="row">
            <div class="col-md-10">
              <%= f.search_field :email_cont, 
                  class: "form-control", 
                  placeholder: t('views.users.index.search_placeholder') %>
            </div>
            <div class="col-md-2">
              <%= f.submit t('views.common.search'), class: "btn btn-primary btn-block" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h3 class="card-title"><%= t('views.users.index.title') %></h3>
      </div>
      
      <div class="card-body p-0">
        <% if @users.any? %>
          <div class="table-responsive">
            <table class="table table-hover">
              <thead>
                <tr>
                  <th><%= sort_link(@q, :id, User.human_attribute_name(:id)) %></th>
                  <th><%= sort_link(@q, :email, User.human_attribute_name(:email)) %></th>
                  <th><%= sort_link(@q, :created_at, User.human_attribute_name(:created_at)) %></th>
                  <th><%= t('views.common.actions') %></th>
                </tr>
              </thead>
              <tbody>
                <% @users.each do |user| %>
                  <tr>
                    <td><strong><%= user.id %></strong></td>
                    <td><strong><%= link_to user.email, user %></strong></td>
                    <td><%= user.created_at.strftime('%d/%m/%Y %H:%M') %></td>
                    <td>
                      <div class="btn-group">
                        <button type="button" class="btn btn-info btn-sm dropdown-toggle" data-toggle="dropdown" aria-expanded="false">
                          <i class="fas fa-cog"></i> <%= t('views.common.actions') %>
                        </button>
                        <div class="dropdown-menu">
                          <%= link_to user, class: "dropdown-item" do %>
                            <i class="fas fa-eye text-info text-center" style="width: 20px;"></i> <%= t('views.common.view') %>
                          <% end %>
                          <%= link_to edit_user_path(user), class: "dropdown-item" do %>
                            <i class="fas fa-edit text-warning text-center" style="width: 20px;"></i> <%= t('views.common.edit') %>
                          <% end %>
                          <div class="dropdown-divider"></div>
                          <%= button_to user, method: :delete, form: { class: "w-100" }, class: "dropdown-item text-danger", style: "background:none;border:0;padding:0;text-align:left;width:100%;", data: { controller: "confirm", action: "submit->confirm#confirm", confirm_message_value: t('views.common.confirm_delete') } do %>
                            <i class="fas fa-trash text-center" style="width: 20px;"></i> <%= t('views.common.delete') %>
                          <% end %>
                        </div>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="text-center py-4">
            <i class="fas fa-users fa-3x text-muted mb-3"></i>
            <p class="text-muted"><%= t('views.users.index.no_records') %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>
