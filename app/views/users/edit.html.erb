<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6">
        <h1 class="m-0">
          <i class="fas fa-edit mr-2"></i><%= t('views.users.edit.header') %>
        </h1>
      </div>
      <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
          <li class="breadcrumb-item"><%= link_to t('views.users.index.header'), users_path %></li>
          <li class="breadcrumb-item"><%= link_to @user.email, @user %></li>
          <li class="breadcrumb-item active"><%= t('breadcrumbs.edit') %></li>
        </ol>
      </div>
    </div>
  </div>
</div>

<section class="content">
  <div class="container-fluid">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title"><%= t('views.users.edit.title') %>: <%= @user.email %></h3>
      </div>
      <div class="card-body">
        <%= render "form", user: @user %>
      </div>
    </div>
    
    <div class="mt-3">
      <%= link_to @user, class: "btn btn-info" do %>
        <i class="fas fa-eye"></i> <%= t('views.common.view') %>
      <% end %>
      <%= link_to users_path, class: "btn btn-secondary" do %>
        <i class="fas fa-arrow-left"></i> <%= t('views.common.back') %>
      <% end %>
    </div>
  </div>
</section>
