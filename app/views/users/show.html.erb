<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6">
        <h1 class="m-0">
          <i class="fas fa-eye mr-2"></i><%= t('views.users.show.title') %>
        </h1>
      </div>
      <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
          <li class="breadcrumb-item"><%= link_to t('views.users.index.header'), users_path %></li>
          <li class="breadcrumb-item active"><%= t('views.users.show.header') %></li>
        </ol>
      </div>
    </div>
  </div>
</div>
<section class="content">
  <div class="container-fluid">
    <%= render @user %>
    
    <div class="mt-3">
      <%= link_to edit_user_path(@user), class: "btn btn-warning" do %>
        <i class="fas fa-edit"></i> <%= t('views.common.edit') %>
      <% end %>
      <%= link_to users_path, class: "btn btn-secondary" do %>
        <i class="fas fa-arrow-left"></i> <%= t('views.common.back') %>
      <% end %>
    </div>
  </div>
</section>
