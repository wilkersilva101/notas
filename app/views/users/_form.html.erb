<%= form_with(model: user) do |form| %>
  <% if user.errors.any? %>
    <div class="alert alert-danger alert-dismissible">
      <button type="button" class="close" data-dismiss="alert" aria-hidden="true">&times;</button>
      <h5><i class="icon fas fa-ban"></i> <%= t('errors.template.header', count: user.errors.count) %></h5>
      <ul>
        <% user.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :email, User.human_attribute_name(:email), style: "display: block" %>
    <%= form.email_field :email, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :password, User.human_attribute_name(:password), style: "display: block" %>
    <%= form.password_field :password, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :password_confirmation, User.human_attribute_name(:password_confirmation), style: "display: block" %>
    <%= form.password_field :password_confirmation, class: "form-control" %>
  </div>

  <div class="mt-4">
    <%= form.submit t('views.common.save'), class: "btn btn-primary" %>
    <%= link_to t('views.common.cancel'), users_path, class: "btn btn-secondary" %>
  </div>
<% end %>
