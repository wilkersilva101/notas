<div class="login-box">
  <div class="login-logo">
    <a href="#"><b>Notas</b></a>
  </div>
  <!-- /.login-logo -->
  <div class="card">
    <div class="card-body login-card-body">
      <p class="login-box-msg">Faça login para iniciar sua sessão</p>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mb-0" }) do |f| %>
        <% if resource.errors.any? %>
          <div class="alert alert-danger alert-dismissible">
            <button type="button" class="close" data-dismiss="alert" aria-hidden="true">&times;</button>
            <% resource.errors.full_messages.each do |message| %>
              <%= message %><br>
            <% end %>
          </div>
        <% end %>

        <div class="input-group mb-3">
          <%= f.email_field :email, class: "form-control", placeholder: "Email", autofocus: true, autocomplete: "email" %>
          <div class="input-group-append">
            <div class="input-group-text">
              <span class="fas fa-envelope"></span>
            </div>
          </div>
        </div>
        <div class="input-group mb-3">
          <%= f.password_field :password, class: "form-control", placeholder: "Senha", autocomplete: "current-password" %>
          <div class="input-group-append">
            <div class="input-group-text">
              <span class="fas fa-lock"></span>
            </div>
          </div>
        </div>
        <div class="row">
          <div class="col-8">
            <% if devise_mapping.rememberable? %>
              <div class="form-check">
                <%= f.check_box :remember_me, class: "form-check-input" %>
                <%= f.label :remember_me, "Lembrar-me", class: "form-check-label" %>
              </div>
            <% end %>
          </div>
          <!-- /.col -->
          <div class="col-4">
            <%= f.submit "Entrar", class: "btn btn-primary btn-block" %>
          </div>
          <!-- /.col -->
        </div>
      <% end %>

      <p class="mb-1">
        <%= link_to "Esqueci minha senha", new_password_path(resource_name) %>
      </p>
      <p class="mb-0">
        <%= link_to "Cadastrar nova conta", new_registration_path(resource_name) %>
      </p>
    </div>
    <!-- /.login-card-body -->
  </div>
</div>
<!-- /.login-box -->
