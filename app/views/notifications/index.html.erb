<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6">
        <h1 class="m-0">Suas Notificações</h1>
      </div>
      <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
          <li class="breadcrumb-item"><a href="/">Início</a></li>
          <li class="breadcrumb-item active">Notificações</li>
        </ol>
      </div>
    </div>
  </div>
</div>

<div class="content">
  <div class="container-fluid">
    <div class="card card-outline card-primary">
      <div class="card-body p-0">
        <table class="table table-hover table-striped">
          <thead>
            <tr>
              <th>Data/Hora</th>
              <th>Mensagem</th>
            </tr>
          </thead>
          <tbody>
            <% if @notifications.any? %>
              <% @notifications.each do |notification| %>
                <tr>
                  <td><%= notification.created_at.strftime("%d/%m/%Y %H:%M") %></td>
                  <td>
                    <% if @unread_ids.include?(notification.id) %>
                      <strong><%= notification.message %></strong> <span class="badge badge-warning">Novo</span>
                    <% else %>
                      <span class="text-muted"><%= notification.message %></span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="2" class="text-center p-3">Nenhuma notificação encontrada.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if @notifications.respond_to?(:total_pages) %>
        <div class="card-footer clearfix d-flex justify-content-center">
          <%= paginate @notifications, theme: 'bootstrap4' %>
        </div>
      <% end %>
    </div>
  </div>
</div>
