<div id="<%= dom_id post %>" class="card">
  <div class="card-header">
    <h3 class="card-title mb-0">
      <i class="fas fa-sticky-note mr-2"></i><%= post.titulo %>
    </h3>
  </div>
  <div class="card-body">
    <p class="card-text"><%= post.descricao %></p>
    <div class="d-flex justify-content-between align-items-center">
      <small class="text-muted">
        <i class="fas fa-user"></i> <%= Post.human_attribute_name(:user_id) %>: <%= post.user.email %>
      </small>
      <div class="btn-group btn-group-sm">
        <%= link_to edit_post_path(post), class: "btn btn-warning mr-1" do %>
          <i class="fas fa-edit"></i> <%= t('views.common.edit') %>
        <% end %>
        <%= button_to post, method: :delete, class: "btn btn-danger", data: { confirm: t('views.common.confirm_delete') } do %>
          <i class="fas fa-trash"></i> <%= t('views.common.delete') %>
        <% end %>
      </div>
    </div>
  </div>
</div>
