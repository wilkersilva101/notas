<%= form_with(model: post, class: "needs-validation", novalidate: true) do |form| %>
  <% if post.errors.any? %>
    <div class="alert alert-danger alert-dismissible">
      <button type="button" class="close" data-dismiss="alert" aria-hidden="true">&times;</button>
      <ul class="mb-0">
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  
   <div class="row">
    <div class="col-md-12">
      <div class="form-group">
        <%= form.label :titulo, class: "form-label" do %>
          <%= Post.human_attribute_name(:titulo) %> <span class="text-danger">*</span>
        <% end %>
        <%= form.text_field :titulo, class: "form-control #{'is-invalid' if post.errors[:titulo].any?}", placeholder: "#{Post.human_attribute_name(:titulo)}..." %>
        <% if post.errors[:titulo].any? %>
          <div class="invalid-feedback">
            <% post.errors[:titulo].each do |error| %>
              <%= error %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-md-12">
      <div class="form-group">
        <%= form.label :descricao, Post.human_attribute_name(:descricao), class: "form-label" %>
        <%= form.text_area :descricao, class: "form-control #{'is-invalid' if post.errors[:descricao].any?}", rows: 5, placeholder: "#{Post.human_attribute_name(:descricao)}..." %>
        <% if post.errors[:descricao].any? %>
          <div class="invalid-feedback">
            <% post.errors[:descricao].each do |error| %>
              <%= error %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="form-group">
        <%= form.submit t('views.common.save'), class: "btn btn-primary" %>
        <%= link_to t('views.common.cancel'), posts_path, class: "btn btn-secondary ml-2" %>
      </div>
    </div>
  </div>
<% end %>
